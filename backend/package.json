{
  "name": "jcourse-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute jcourse-db --file=./schema.sql",
    "db:init:local": "wrangler d1 execute jcourse-db --local --file=./schema.sql",
    "db:seed:local": "wrangler d1 execute jcourse-db --local --file=./sample_data.sql",
    "db:seed:pk:local": "wrangler d1 execute jcourse-db --local --file=./sample_pk_data.sql",
    "db:merge:icu": "python3 ./scripts/merge_icu_d1.py",
    "db:verify:icu": "python3 ./scripts/verify_merged_d1.py",
    "pk:sync:local": "node ./scripts/pk-sync-local.mjs",
    "pk:sync:login": "python ./scripts/pk-login-and-sync.py"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "hono": "^4.0.0",
    "sqids": "^0.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260605.1",
    "typescript": "^5.3.0",
    "wrangler": "4.98.0"
  }
}
